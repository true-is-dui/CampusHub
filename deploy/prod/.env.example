# CampusHub 生产环境 MySQL 配置模板
# 复制为同目录下的 .env 并填入真实值后再启动：
#   cp .env.example .env
# .env 含真实密码，已被 .gitignore 忽略，请勿提交。

# MySQL root 密码（占位符，请改成你自己的）
MYSQL_ROOT_PASSWORD=changeme

# 初始化创建的数据库名
MYSQL_DATABASE=database

# 初始化创建的用户名，用于后端数据库操作
MYSQL_USER=user

# MYSQL_USER 的密码
MYSQL_PASSWORD=changeme

# jwt密钥，长度至少为32字节
JWT_SECRET=jwt-secret-example-at-least-32-bytes

# 后端文件存储根目录（容器内）
FILE_STORAGE_ROOT=/app/uploads

# 前端docker镜像仓库地址
FRONTEND_IMAGE=url

# 后端docker镜像仓库地址
BACKEND_IMAGE=url

######################################################
# ------------------以下环境变量非必须------------------#
######################################################


# 后端在容器内使用的端口，应与 nginx/default.conf 中的配置一致，默认值为8080
# SERVER_PORT=8080

# JWT有效期，默认值为24h
# JWT_EXPIRATION=24h


